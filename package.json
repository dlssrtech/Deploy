{
  "name": "topdesign-website",
  "version": "1.0.0",
  "description": "TOP DESIGN - Website Design, App Design, Digital Marketing, SEO, Interior Design & Printing Services",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss src/css/main.css -o public/css/main.min.css",
    "build:js": "uglifyjs src/js/*.js -o public/js/main.min.js",
    "test": "jest",
    "lint": "eslint src/",
    "deploy": "npm run build && pm2 start ecosystem.config.js",
    "logs": "pm2 logs topdesign",
    "stop": "pm2 stop topdesign"
  },
  "keywords": [
    "website-design",
    "app-design",
    "digital-marketing",
    "seo",
    "interior-design",
    "printing",
    "delhi"
  ],
  "author": "TOP DESIGN Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.1.5",
    "nodemailer": "^6.9.7",
    "multer": "^1.4.5-lts.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.1",
    "uglify-js": "^3.17.4",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
